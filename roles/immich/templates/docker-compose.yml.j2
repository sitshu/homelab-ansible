---
services:
  immich-server:
    container_name: immich-server
    image: ghcr.io/immich-app/immich-server:{{ versions.immich }}
    restart: unless-stopped
    networks: [homelab]
    ports:
      - "{{ ports.immich }}:2283"
    volumes:
      - "{{ paths.photos_root }}:/usr/src/app/upload"
      - /etc/localtime:/etc/localtime:ro
    environment:
      DB_HOSTNAME: immich-postgres
      DB_USERNAME: postgres
      DB_PASSWORD: "{{ vault_immich_db_password }}"
      DB_DATABASE_NAME: immich
      REDIS_HOSTNAME: immich-redis
      TZ: "{{ timezone }}"
    depends_on: [immich-postgres, immich-redis, immich-machine-learning]

  immich-machine-learning:
    container_name: immich-machine-learning
    image: ghcr.io/immich-app/immich-machine-learning:{{ versions.immich }}
    restart: unless-stopped
    networks: [homelab]
    volumes:
      - "{{ paths.docker_data }}/immich/ml-cache:/cache"

  immich-redis:
    container_name: immich-redis
    image: "redis:{{ versions.redis }}"
    restart: unless-stopped
    networks: [homelab]
    healthcheck:
      test: redis-cli ping || exit 1

  immich-postgres:
    container_name: immich-postgres
    image: "tensorchord/pgvecto-rs:pg16-v0.2.0"
    restart: unless-stopped
    networks: [homelab]
    environment:
      POSTGRES_PASSWORD: "{{ vault_immich_db_password }}"
      POSTGRES_USER: postgres
      POSTGRES_DB: immich
    volumes:
      - "{{ paths.docker_data }}/immich/db:/var/lib/postgresql/data"

networks:
  homelab:
    external: true
